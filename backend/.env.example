# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Firebase Admin ───────────────────────────────────────
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"aria-hr",...}
FIREBASE_PROJECT_ID=aria-hr

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── Redis (Bull queues) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Gmail SMTP) ───────────────────────────────────
EMAIL_USER=aria@yourdomain.com
EMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM=ARIA HR <aria@yourdomain.com>

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ─── Plans (Stripe Price IDs) ─────────────────────────────
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_GROWTH=price_growth_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id
